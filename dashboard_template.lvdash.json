{
  "datasets": [
    {
      "name": "governance_results",
      "displayName": "Governance Results",
      "queryLines": [
        "SELECT category, details, remediation, score, status, task_name, timestamp, max_score, score_percentage, concat(score,'/',max_score) as fraction_score, CASE WHEN status = 'fail' THEN 1 WHEN status = 'warning' THEN 2 WHEN status = 'error' THEN 3 ELSE 4 END AS severity_order FROM {catalog}.{schema}.governance_results"
      ],
      "columns": [
        {
          "displayName": "Pass Rate",
          "description": "Percentage of checks that passed",
          "expression": "SUM(CASE WHEN status = 'pass' THEN 1 ELSE 0 END) * 100.0 / COUNT(*)"
        },
        {
          "displayName": "Maturity Score",
          "description": "Overall governance maturity score (0-100)",
          "expression": "ROUND(AVG(score_percentage), 1)"
        },
        {
          "displayName": "Maturity Level",
          "description": "Governance maturity tier",
          "expression": "CASE WHEN AVG(score_percentage) >= 95 THEN 'Leading' WHEN AVG(score_percentage) >= 80 THEN 'Advanced' WHEN AVG(score_percentage) >= 60 THEN 'Established' WHEN AVG(score_percentage) >= 40 THEN 'Developing' ELSE 'Foundational' END"
        }
      ]
    }
  ],
