{
  "datasets": [
    {
      "name": "governance_results",
      "displayName": "Governance Results",
      "queryLines": [
        "SELECT category, details, remediation, score, status, task_name, timestamp, max_score, score_percentage FROM {catalog}.{schema}.governance_results"
      ],
      "columns": [
        {
          "displayName": "Pass Rate",
          "description": "Percentage of checks that passed",
          "expression": "SUM(CASE WHEN status = 'pass' THEN 1 ELSE 0 END) * 100.0 / COUNT(*)"
        },
        {
          "displayName": "Maturity Score",
          "description": "Overall governance maturity score (0-100)",
          "expression": "ROUND(AVG(score_percentage), 1)"
        },
        {
          "displayName": "Maturity Level",
          "description": "Governance maturity tier",
          "expression": "CASE WHEN AVG(score_percentage) >= 95 THEN 'Leading' WHEN AVG(score_percentage) >= 80 THEN 'Advanced' WHEN AVG(score_percentage) >= 60 THEN 'Established' WHEN AVG(score_percentage) >= 40 THEN 'Developing' ELSE 'Foundational' END"
        }
      ]
    },
    {
      "name": "governance_results_issues",
      "displayName": "Governance Issues",
      "queryLines": [
        "SELECT category, details, remediation, score, status, task_name, timestamp, max_score, score_percentage FROM {catalog}.{schema}.governance_results WHERE status IN ('fail', 'warning', 'error')"
      ]
    },
    {
      "name": "access_security_results",
      "displayName": "Identity & Access Results",
      "queryLines": [
        "SELECT category, details, remediation, score, status, task_name, timestamp, max_score, score_percentage FROM {catalog}.{schema}.governance_results WHERE category IN ('Identity & Access')"
      ]
    },
    {
      "name": "data_quality_results",
      "displayName": "Data Quality & Infrastructure Results",
      "queryLines": [
        "SELECT category, details, remediation, score, status, task_name, timestamp, max_score, score_percentage FROM {catalog}.{schema}.governance_results WHERE category IN ('Data Protection', 'Platform Setup', 'Data Quality & Observability', 'AI & Model Governance')"
      ]
    }
  ],
